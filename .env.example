# ── STT Backend ────────────────────────────────────────────────────────────
# Options: "local" (uses HuggingFace Whisper) or "groq" (uses Groq API)
STT_BACKEND=local

# ── Groq API (only needed if STT_BACKEND=groq) ─────────────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Ollama (intent + code generation) ──────────────────────────────────────
# Default model — change to llama3.1, mistral, gemma2 etc.
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
